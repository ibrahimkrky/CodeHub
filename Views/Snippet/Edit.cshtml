@model SnippetFormViewModel
@{
    ViewData["Title"] = "Snippet Düzenle";
}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <h2 class="section-title"><i class="bi bi-pencil-square"></i> Snippet Düzenle</h2>
        <div class="ch-form-card">
            <form asp-action="Edit" method="post" id="snippetForm">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label">Başlık</label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Language" class="form-label">Dil</label>
                    <select asp-for="Language" class="form-select" asp-items="ViewBag.Languages"></select>
                    <span asp-validation-for="Language" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Code" class="form-label">Kod</label>
                    <textarea asp-for="Code" class="form-control ch-code" id="codeArea"></textarea>
                    <span asp-validation-for="Code" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Açıklama</label>
                    <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Etiketler</label>
                    <input type="text" id="tagInput" class="form-control"
                           placeholder="Etiket yaz ve Enter'a bas" />
                    <input type="hidden" asp-for="TagsCsv" id="tagsCsv" />
                    <div id="tagBadges" class="mt-2"></div>
                </div>

                <button type="submit" class="btn btn-accent">Güncelle</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-ch">İptal</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/snippet-form.js"></script>
}
