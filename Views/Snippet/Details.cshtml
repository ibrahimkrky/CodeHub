@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@model Snippet
@{
    ViewData["Title"] = Model.Title;
    var currentUserId = UserManager.GetUserId(User);
    var isOwner = currentUserId == Model.AuthorId;
    var langClass = Model.Language.ToLower() switch {
        "c#" => "csharp", "asp.net" => "csharp", _ => Model.Language.ToLower()
    };
}

<div class="row">
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <span class="ch-badge">@Model.Language</span>
            @if (isOwner)
            {
                <div>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-ch btn-sm">
                        <i class="bi bi-pencil"></i> Düzenle
                    </a>
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline confirm-form"
                          data-confirm-message="Bu snippet kalıcı olarak silinecek. Devam etmek istiyor musun?">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-ch btn-sm text-danger">
                            <i class="bi bi-trash"></i> Sil
                        </button>
                    </form>
                </div>
            }
        </div>

        <h1 class="mb-2">@Model.Title</h1>
        <p class="text-muted-ch">@Model.Description</p>

        @if (TempData["Info"] != null)
        {
            <div class="alert alert-success py-2">@TempData["Info"]</div>
        }

        <div class="d-flex align-items-center gap-3 mb-3 text-muted-ch small">
            <span><i class="bi bi-person"></i> @(Model.Author?.DisplayName ?? "anon")</span>
            <span><i class="bi bi-calendar3"></i> @Model.CreatedAt.ToString("dd.MM.yyyy")</span>
            <span><i class="bi bi-eye"></i> @Model.ViewCount görüntülenme</span>
        </div>

        <div class="position-relative">
            <button class="btn btn-outline-ch btn-sm position-absolute top-0 end-0 m-2"
                    id="copyBtn" onclick="copyCode()">
                <i class="bi bi-clipboard"></i> Kopyala
            </button>
            <pre><code class="language-@langClass">@Model.Code</code></pre>
        </div>

        <div class="mt-3">
            @foreach (var st in Model.SnippetTags)
            {
                <span class="ch-tag me-2">#@st.Tag?.Name</span>
            }
        </div>

        <div class="mt-4 d-flex align-items-center gap-2 flex-wrap">
            @if (SignInManager.IsSignedIn(User))
            {
                <button class="star-btn" id="starBtn" data-id="@Model.Id" onclick="toggleStar()">
                    <i class="bi bi-star"></i> Beğen (<span id="likeCount">@Model.LikeCount</span>)
                </button>

                var cols = ViewBag.MyCollections as List<Collection> ?? new List<Collection>();
                <div class="dropdown">
                    <button class="btn btn-outline-ch" data-bs-toggle="dropdown">
                        <i class="bi bi-folder-plus"></i> Koleksiyona Ekle
                    </button>
                    <ul class="dropdown-menu ch-dropdown">
                        @if (cols.Any())
                        {
                            foreach (var c in cols)
                            {
                                <li>
                                    <form asp-controller="Collection" asp-action="AddSnippet" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="collectionId" value="@c.Id" />
                                        <input type="hidden" name="snippetId" value="@Model.Id" />
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-folder2"></i> @c.Name
                                        </button>
                                    </form>
                                </li>
                            }
                        }
                        else
                        {
                            <li><span class="dropdown-item-text text-muted-ch small">Önce koleksiyon oluştur</span></li>
                        }
                        <li><hr class="dropdown-divider" style="border-color:var(--border)"></li>
                        <li>
                            <a class="dropdown-item" asp-controller="Collection" asp-action="MyCollections">
                                <i class="bi bi-gear"></i> Koleksiyonları yönet
                            </a>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <span class="text-muted-ch small">
                    <i class="bi bi-star"></i> @Model.LikeCount beğeni —
                    <a asp-controller="Account" asp-action="Login">beğenmek için giriş yap</a>
                </span>
            }
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/snippet-details.js"></script>
}
