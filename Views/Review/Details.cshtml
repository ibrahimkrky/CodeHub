@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@model Review
@{
    ViewData["Title"] = Model.Title;
    var currentUserId = UserManager.GetUserId(User);
    var isReviewOwner = currentUserId == Model.AuthorId;
}

<div class="row">
    <div class="col-lg-7">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h1 class="mb-0">@Model.Title</h1>
            @if (isReviewOwner)
            {
                <div class="d-flex gap-2 flex-shrink-0">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-ch btn-sm" title="Düzenle">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <form asp-action="Delete" method="post" class="d-inline confirm-form"
                          data-confirm-message="Bu kod incelemesi ve tüm yorumları kalıcı olarak silinecek. Devam etmek istiyor musun?">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-ch btn-sm text-danger" title="Sil">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>
            }
        </div>
        <div class="d-flex gap-3 text-muted-ch small mb-3">
            <span><i class="bi bi-person"></i> @(Model.Author?.DisplayName ?? "anon")</span>
            @if (Model.Language != null) { <span class="ch-badge">@Model.Language</span> }
        </div>
        <p class="text-muted-ch">@Model.Problem</p>
        <pre><code>@Model.Code</code></pre>
    </div>

    <div class="col-lg-5">
        <h5 class="mb-3"><i class="bi bi-lightbulb text-warning"></i> Çözüm Önerileri</h5>

        @foreach (var c in Model.Comments)
        {
            var voteTotal = c.Votes.Sum(v => v.Value);
            var isCommentOwner = currentUserId == c.AuthorId;
            var myExisting = c.Votes.FirstOrDefault(v => v.UserId == currentUserId);
            var upClass = myExisting?.Value == 1 ? "voted" : "";
            var downClass = myExisting?.Value == -1 ? "voted" : "";
            <div class="comment-card @(c.IsSolution ? "solution" : "")">
                @if (c.IsSolution)
                {
                    <div class="text-success small mb-1"><i class="bi bi-check-circle-fill"></i> Kabul edilen çözüm</div>
                }
                <p class="mb-2 comment-body" id="body-@c.Id">@c.Body</p>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="ch-tag">@@@(c.Author?.DisplayName ?? "anon")</span>
                    <div class="d-flex align-items-center gap-2">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <div class="vote-controls" data-comment="@c.Id">
                                <button id="up-@c.Id" class="@upClass" onclick="vote(@c.Id, 1)"><i class="bi bi-arrow-up-circle"></i></button>
                                <span class="vote-total">@voteTotal</span>
                                <button id="down-@c.Id" class="@downClass" onclick="vote(@c.Id, -1)"><i class="bi bi-arrow-down-circle"></i></button>
                            </div>
                            @if (isReviewOwner)
                            {
                                <form asp-action="MarkSolution" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="commentId" value="@c.Id" />
                                    @if (c.IsSolution)
                                    {
                                        <button type="submit" class="btn btn-outline-ch btn-sm text-success" title="Çözüm işaretini kaldır">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-outline-ch btn-sm" title="Çözüm olarak işaretle">
                                            <i class="bi bi-check2"></i>
                                        </button>
                                    }
                                </form>
                            }
                            @if (isCommentOwner)
                            {
                                <button type="button" class="btn btn-outline-ch btn-sm" title="Düzenle"
                                        onclick="startEdit(@c.Id)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <form asp-action="DeleteComment" method="post" class="d-inline confirm-form"
                                      data-confirm-message="Bu yorum kalıcı olarak silinecek. Devam etmek istiyor musun?">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="commentId" value="@c.Id" />
                                    <button type="submit" class="btn btn-outline-ch btn-sm text-danger" title="Sil">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        }
                        else
                        {
                            <span class="ch-tag">@voteTotal oy</span>
                        }
                    </div>
                </div>

                @* Düzenleme formu — normalde gizli, kalem ikonuna basınca açılır *@
                @if (isCommentOwner)
                {
                    <form asp-action="EditComment" method="post" class="mt-2 edit-form" id="edit-@c.Id" style="display:none;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="commentId" value="@c.Id" />
                        <textarea name="body" class="form-control mb-2" rows="2" required>@c.Body</textarea>
                        <button type="submit" class="btn btn-accent btn-sm">Kaydet</button>
                        <button type="button" class="btn btn-outline-ch btn-sm" onclick="cancelEdit(@c.Id)">İptal</button>
                    </form>
                }
            </div>
        }

        @if (SignInManager.IsSignedIn(User))
        {
            <form asp-action="AddComment" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="reviewId" value="@Model.Id" />
                <textarea name="body" class="form-control mb-2" rows="3"
                          placeholder="Çözüm öner......" required></textarea>
                <button type="submit" class="btn btn-accent btn-sm">Yorum Ekle</button>
            </form>
        }
        else
        {
            <p class="text-muted-ch small mt-3">
                <a asp-controller="Account" asp-action="Login">Giriş yap</a> ve çözüm öner.
            </p>
        }
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/review-vote.js"></script>
}
