@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@model List<Review>
@{
    ViewData["Title"] = "Kod İnceleme";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="section-title mb-0"><i class="bi bi-chat-square-text"></i> Kod İnceleme Odası</h2>
    @if (SignInManager.IsSignedIn(User))
    {
        <a asp-action="Create" class="btn btn-accent btn-sm"><i class="bi bi-plus-lg"></i> Yardım İste</a>
    }
</div>

<p class="text-muted-ch">Takıldığın kodu paylaş, topluluktan çözüm önerileri al.</p>

<div class="sort-bar mb-3">
    <span class="text-muted-ch small me-1"><i class="bi bi-sort-down"></i> Sırala:</span>
    <a asp-action="Index" asp-route-sort="new"
       class="sort-link @(((string)ViewBag.CurrentSort) == "new" ? "active" : "")">En Yeni</a>
    <a asp-action="Index" asp-route-sort="comments"
       class="sort-link @(((string)ViewBag.CurrentSort) == "comments" ? "active" : "")">En Çok Yorum</a>
    <a asp-action="Index" asp-route-sort="unsolved"
       class="sort-link @(((string)ViewBag.CurrentSort) == "unsolved" ? "active" : "")">Çözülmemişler</a>
    <a asp-action="Index" asp-route-sort="solved"
       class="sort-link @(((string)ViewBag.CurrentSort) == "solved" ? "active" : "")">Çözülenler</a>
</div>

@foreach (var r in Model)
{
    <div class="ch-card clickable mb-3" data-href="@Url.Action("Details", "Review", new { id = r.Id })">
        <div class="card-body">
            <div class="d-flex justify-content-between">
                <h5 class="card-title">
                    <a asp-action="Details" asp-route-id="@r.Id">@r.Title</a>
                </h5>
                @if (r.Comments.Any(c => c.IsSolution))
                {
                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Çözüldü</span>
                }
            </div>
            <p class="text-muted-ch small mb-2">@r.Problem</p>
            <div class="d-flex gap-3 text-muted-ch small">
                <span><i class="bi bi-person"></i> @(r.Author?.DisplayName ?? "anon")</span>
                <span><i class="bi bi-chat"></i> @r.Comments.Count yorum</span>
                @if (r.Language != null) { <span class="ch-badge">@r.Language</span> }
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/card-click.js"></script>
}
