@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@{
    // Tema tercihini cookie'den oku (yoksa varsayılan: dark)
    var theme = Context.Request.Cookies["theme"] == "light" ? "light" : "dark";
}
<!DOCTYPE html>
<html lang="tr" data-theme="@theme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · CodeHub</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link id="hljs-dark" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css" />
    <link id="hljs-light" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-light.min.css" disabled />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg ch-navbar sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="ch-logo">&lt;/&gt;</span> CodeHub
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Keşfet</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Tag" asp-action="Index">Etiketler</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Review" asp-action="Index">Kod İnceleme</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Community" asp-action="Leaderboard">Liderlik</a></li>
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Collection" asp-action="MyCollections">Koleksiyonlarım</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Analytics" asp-action="Index">Analiz</a></li>
                    }
                </ul>
                <ul class="navbar-nav align-items-lg-center">
                    <li class="nav-item me-lg-2">
                        <button id="themeToggle" class="theme-toggle" type="button"
                                onclick="toggleTheme()" title="Tema değiştir" aria-label="Tema değiştir">
                            <i class="bi bi-sun-fill icon-light"></i>
                            <i class="bi bi-moon-stars-fill icon-dark"></i>
                        </button>
                    </li>
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item">
                            <a class="btn btn-accent btn-sm me-2" asp-controller="Snippet" asp-action="Create">
                                <i class="bi bi-plus-lg"></i> Yeni Snippet
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">
                                <i class="bi bi-person-circle"></i> @User.Identity?.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end ch-dropdown">
                                <li>
                                    <a class="dropdown-item" asp-controller="Profile" asp-action="Index">
                                        <i class="bi bi-person"></i> Profilim
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="px-3 py-1">
                                        <button type="submit" class="btn btn-link p-0 text-decoration-none">Çıkış Yap</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Giriş</a></li>
                        <li class="nav-item"><a class="btn btn-accent btn-sm" asp-controller="Account" asp-action="Register">Kayıt Ol</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="ch-footer">
        <div class="container">
            <span>CodeHub &mdash; Kod Parçacığı ve Geliştirici Kaynak Merkezi</span>
        </div>
    </footer>

    <!-- Paylaşılan onay modalı (silme işlemleri için) -->
    <div class="modal fade" id="confirmModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background:var(--bg-card); border:1px solid var(--border);">
                <div class="modal-header" style="border-color:var(--border);">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-danger"></i> <span id="confirmTitle">Emin misin?</span></h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p id="confirmMessage" class="mb-0">Bu işlem geri alınamaz.</p>
                </div>
                <div class="modal-footer" style="border-color:var(--border);">
                    <button type="button" class="btn btn-outline-ch" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="button" class="btn btn-accent" id="confirmOkBtn" style="background:var(--red);border:none;color:#fff;">
                        <i class="bi bi-trash"></i> Sil
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script>hljs.highlightAll();</script>
    <script>
        // Aktif temaya göre doğru highlight.js stilini etkinleştir
        function applyHljsTheme() {
            var isLight = document.documentElement.getAttribute('data-theme') === 'light';
            var dark = document.getElementById('hljs-dark');
            var light = document.getElementById('hljs-light');
            if (dark) dark.disabled = isLight;
            if (light) light.disabled = !isLight;
        }
        applyHljsTheme(); // sayfa açılışında

        // Tema değiştir: html data-theme + cookie (1 yıl). Tüm sayfalarda kalıcı.
        function toggleTheme() {
            var html = document.documentElement;
            var current = html.getAttribute('data-theme');
            var next = current === 'light' ? 'dark' : 'light';
            html.setAttribute('data-theme', next);
            document.cookie = 'theme=' + next + ';path=/;max-age=' + (60 * 60 * 24 * 365);
            applyHljsTheme(); // kod renklerini de güncelle
        }

        // Paylaşılan onay modalı: "confirm-form" sınıflı formlar gönderilmeden önce modal açar
        (function () {
            var pendingForm = null;
            var modalEl = document.getElementById('confirmModal');
            if (!modalEl) return;
            var modal = new bootstrap.Modal(modalEl);
            var okBtn = document.getElementById('confirmOkBtn');

            document.querySelectorAll('form.confirm-form').forEach(function (form) {
                form.addEventListener('submit', function (e) {
                    if (form.dataset.confirmed === 'true') return; // onaylandı, gerçekten gönder
                    e.preventDefault();
                    pendingForm = form;
                    // Forma özel mesaj varsa kullan
                    var msg = form.getAttribute('data-confirm-message');
                    document.getElementById('confirmMessage').innerText =
                        msg || 'Bu işlem geri alınamaz. Devam etmek istiyor musun?';
                    modal.show();
                });
            });

            okBtn.addEventListener('click', function () {
                if (pendingForm) {
                    pendingForm.dataset.confirmed = 'true';
                    modal.hide();
                    pendingForm.submit();
                }
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
