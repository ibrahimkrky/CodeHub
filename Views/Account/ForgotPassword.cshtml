@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Şifremi Unuttum";
}
<div class="auth-wrap">
    <div class="auth-card">
        <span class="ch-logo-big">&lt;/&gt;</span>
        <h2 class="text-center mb-1">Şifreni mi unuttun?</h2>
        <p class="text-center text-muted-ch mb-4">Hesabının e-postasını gir, yeni parola belirle</p>

        <form asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="ornek@@codehub.dev" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-accent w-100">Devam Et</button>
        </form>

        <p class="text-center text-muted-ch mt-3 mb-0 small">
            <a asp-action="Login"><i class="bi bi-arrow-left"></i> Girişe dön</a>
        </p>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
