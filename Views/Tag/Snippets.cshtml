@model List<Snippet>
@{
    ViewData["Title"] = ViewBag.TagName + " etiketi";
}
<div class="d-flex align-items-center gap-2 mb-1">
    <a asp-action="Index" class="text-muted-ch"><i class="bi bi-arrow-left"></i> Etiketler</a>
</div>
<h2 class="section-title"><i class="bi bi-tag"></i> #@ViewBag.TagName <span class="text-muted-ch" style="font-size:1rem;">(@Model.Count snippet)</span></h2>

@if (!Model.Any())
{
    <div class="text-center text-muted-ch py-5">
        <i class="bi bi-inbox" style="font-size:2rem;"></i>
        <p class="mt-2">Bu etikete ait snippet yok.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var s in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="ch-card clickable h-100" data-href="@Url.Action("Details", "Snippet", new { id = s.Id })">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="ch-badge">@s.Language</span>
                            <small class="text-muted-ch"><i class="bi bi-star-fill text-warning"></i> @s.LikeCount</small>
                        </div>
                        <h5 class="card-title">
                            <a asp-controller="Snippet" asp-action="Details" asp-route-id="@s.Id">@s.Title</a>
                        </h5>
                        <p class="text-muted-ch small mb-2">@s.Description</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="ch-tag">@@@(s.Author?.DisplayName ?? "anon")</span>
                            <small class="text-muted-ch"><i class="bi bi-eye"></i> @s.ViewCount</small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script src="~/js/card-click.js"></script>
}
